      "options": {
        "dataLinks": [],
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "11.3.0",
      "targets": [
        {
          "datasource": "${grafana_data_source}",
          "editorMode": "code",
          "expr": "rate(hkube_pipeline_driver_pipeline_net_time_took_histogram_sum[1m]) / rate(hkube_pipeline_driver_pipeline_net_time_took_histogram_count[1m])",
          "format": "time_series",
          "interval": "30s",
          "intervalFactor": 1,
          "legendFormat": "{{pipeline_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pipeline Net Time - Avg (completed) [30s]",
      "type": "timeseries"
    },
    {
